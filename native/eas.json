{
  "cli": {
    "appVersionSource": "remote",
    "requireCommit": true,
    "version": ">= 21.1.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "OPENJOB_NATIVE_ENV": "development"
      },
      "ios": {
        "credentialsSource": "remote"
      }
    },
    "preview": {
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true,
      "distribution": "store",
      "environment": "preview",
      "env": {
        "OPENJOB_NATIVE_ENV": "preview"
      },
      "ios": {
        "credentialsSource": "remote"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true,
      "distribution": "store",
      "environment": "production",
      "env": {
        "OPENJOB_NATIVE_ENV": "production"
      },
      "ios": {
        "credentialsSource": "remote"
      }
    }
  }
}

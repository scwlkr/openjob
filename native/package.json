{
  "name": "@openjob/native",
  "version": "0.3.3",
  "private": true,
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "expo start --dev-client",
    "simulators": "expo start --dev-client --ios --android",
    "ios": "node scripts/run-local.mjs ios development debug",
    "android": "node scripts/run-local.mjs android development debug",
    "ios:preview": "node scripts/run-local.mjs ios preview release",
    "android:preview": "node scripts/run-local.mjs android preview release",
    "ios:release": "node scripts/run-local.mjs ios production release",
    "android:release": "node scripts/run-local.mjs android production release",
    "prebuild": "expo prebuild --clean --no-install",
    "build:development:ios": "npx --yes eas-cli@21.1.0 build --platform ios --profile development",
    "build:development:android": "npx --yes eas-cli@21.1.0 build --platform android --profile development",
    "build:preview": "npx --yes eas-cli@21.1.0 build --platform all --profile preview",
    "build:production": "npx --yes eas-cli@21.1.0 build --platform all --profile production",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "secret:check": "node ../scripts/check-v1-secrets.mjs",
    "config:verify": "node scripts/verify-config.mjs",
    "bundle:verify": "node scripts/verify-embedded-bundles.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run secret:check && npm run config:verify && npm run bundle:verify"
  },
  "dependencies": {
    "@expo-google-fonts/geist": "0.4.2",
    "@expo/vector-icons": "15.1.1",
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "7.3.13",
    "@react-navigation/native-stack": "7.18.5",
    "expo": "~57.0.8",
    "expo-asset": "~57.0.7",
    "expo-constants": "~57.0.7",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.8",
    "expo-font": "~57.0.1",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-updates": "~57.0.9",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "14.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "9.39.4",
    "eslint-config-expo": "57.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  }
}

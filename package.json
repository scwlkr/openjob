{
  "name": "openjob",
  "version": "0.3.3",
  "private": true,
  "bin": {
    "openjob": "cli/openjob.mjs"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prototype:assignee-columns": "OPENJOB_ASSIGNEE_COLUMNS_PROTOTYPE=1 WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prototype:cli": "node prototypes/cli/openjob.mjs",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "cli:types": "openapi-typescript openapi/openapi.yaml -o cli/generated/openapi.d.ts",
    "cli:types:check": "openapi-typescript openapi/openapi.yaml -o cli/generated/openapi.d.ts --check",
    "cli:pack": "npm pack ./cli",
    "cli:smoke:production": "node scripts/smoke-cli-production.mjs",
    "release:prepare": "node scripts/release.mjs prepare",
    "release:publish": "node scripts/release.mjs publish",
    "deploy": "node scripts/release.mjs deploy",
    "deploy:raw": "vinext deploy",
    "firebase:deploy:rules": "npx -y firebase-tools@latest deploy --only firestore --project openjob-dev",
    "openapi:check": "node scripts/validate-openapi.mjs",
    "test": "npm run build && npm run secret:check && npm run cli:types:check && node --test tests/*.test.mjs && npm run test:browser",
    "test:browser": "playwright install chromium && playwright test --config tests/browser/playwright.config.ts",
    "secret:check": "node scripts/check-v1-secrets.mjs",
    "legacy:smoke": "node scripts/legacy-cutover.mjs smoke",
    "legacy:snapshot": "node scripts/legacy-cutover.mjs snapshot",
    "legacy:retire": "node scripts/legacy-cutover.mjs retire",
    "smoke:production": "node scripts/smoke-v1-production.mjs",
    "cf:typegen": "wrangler types cloudflare-env.d.ts --env-interface CloudflareEnv",
    "typecheck": "npm run cf:typegen && tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@napi-rs/keyring": "1.3.0",
    "@pushforge/builder": "2.0.5",
    "firebase": "12.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "@cloudflare/vite-plugin": "1.37.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "openapi-typescript": "7.13.0",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0",
    "yaml": "2.9.0"
  },
  "type": "module"
}
